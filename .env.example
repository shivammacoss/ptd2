# =============================================================
# ProTrader PTD2 — Root .env.example
# Copy to .env and fill in your values before running docker-compose
# =============================================================

# ─── PostgreSQL (main) ───────────────────────────────────────
POSTGRES_USER=protrader
POSTGRES_PASSWORD=protrader_dev
POSTGRES_DB=protrader

# ─── TimescaleDB (market data) ───────────────────────────────
TIMESCALE_USER=protrader
TIMESCALE_PASSWORD=protrader_dev
TIMESCALE_DB=marketdata

# ─── Connection URLs ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://protrader:protrader_dev@postgres:5432/protrader
TIMESCALE_URL=postgresql+asyncpg://protrader:protrader_dev@timescaledb:5432/marketdata
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── JWT Secrets (change ALL of these in production!) ────────
JWT_SECRET=dev-secret-change-in-production
USER_JWT_SECRET=dev-secret-change-in-production
ADMIN_JWT_SECRET=admin-secret-change-in-production

# ─── Gateway service (port 8000) ─────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# ─── Admin service (port 8001) ───────────────────────────────
# REDIS_URL for admin defaults to redis://redis:6379/1 (separate DB index)
ADMIN_REDIS_URL=redis://redis:6379/1

# ─── Risk engine ─────────────────────────────────────────────
MARGIN_CALL_LEVEL=80.0
STOP_OUT_LEVEL=50.0
MAX_OPEN_TRADES=200
DEFAULT_LEVERAGE=100
