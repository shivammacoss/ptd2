# =============================================================
# ProTrader Admin Frontend — .env.example
# Copy to .env.local for local development
# =============================================================
# Production: host the admin app on https://protrader.today (path or subdomain you configure
# in nginx/Cloudflare). Same-origin /admin-api proxy then targets the admin API container.
# =============================================================

# URL of the trader gateway API (used for rewrites in next.config.ts)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# Optional: call admin API directly (must include /api/v1/admin if you set full path).
# Leave unset to use same-origin /admin-api (proxied to admin service — recommended).
# NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8001

# Server-side only: where Next.js proxies /admin-api/* (docker: http://admin-api:8001)
ADMIN_API_PROXY_TARGET=http://127.0.0.1:8001

# Rewrites /api/* on admin app to gateway (docker: http://gateway:8000)
GATEWAY_INTERNAL_URL=http://127.0.0.1:8000

# WebSocket URL for real-time admin stream
NEXT_PUBLIC_WS_URL=ws://localhost:8000
