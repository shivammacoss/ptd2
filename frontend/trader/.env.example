# =============================================================
# ProTrader Trader Frontend — .env.example
# Copy to .env.local for local development
# =============================================================

# URL of the gateway API (used for rewrites in next.config.ts)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# WebSocket origin (scheme + host:port, no path). Use wss:// when the site is served over HTTPS.
# If unset, HTTP dev uses ws://localhost:8000; HTTPS pages use wss://<current host> (proxy /ws to gateway).
# Trading UI also polls GET /api/v1/instruments/prices/all every 2.5s so bid/ask work without WS if nginx omits /ws.
NEXT_PUBLIC_WS_URL=ws://localhost:8000
